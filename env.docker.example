# Docker Environment Variables
# Copy this to .env when using Docker, or merge with your existing .env

APP_NAME=Colify
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database - MySQL (Docker)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=colify
DB_USERNAME=colify
DB_PASSWORD=secret

# Session & Cache (use database for Docker)
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# Vite - for HMR in Docker
VITE_DEV_SERVER_URL=http://localhost:5173
